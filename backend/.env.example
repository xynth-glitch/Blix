# Copy to .env and adjust. All vars are prefixed BLIX_.

BLIX_DATABASE_URL=postgresql+psycopg://blix:blix@localhost:5432/blix

# Delhi OTD provider
BLIX_OTD_BASE_URL=https://otd.delhi.gov.in
# Optional: a stable mirror/local URL for the static GTFS.zip (reproducible ingestion).
# BLIX_OTD_STATIC_GTFS_URL=

# Real-time VehiclePositions private key (register at
# https://otd.delhi.gov.in/data/realtime/ to obtain one). Leave empty to disable RT.
BLIX_OTD_REALTIME_KEY=

# Real-time poller
BLIX_RT_POLL_INTERVAL_SECONDS=15
BLIX_RT_STALE_AFTER_SECONDS=60
